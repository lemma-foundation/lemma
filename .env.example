# Lemma v1 uses normal Bittensor miner/validator emissions.
# Do not put private keys, mnemonics, API keys, or machine-local notes in files that may be committed.

# Task registry
LEMMA_TASK_REGISTRY_URL="tasks/registry.json"
# Optional pin for published registries.
# LEMMA_TASK_REGISTRY_SHA256_EXPECTED=""
LEMMA_TASK_HTTP_TIMEOUT_S="30"

# Public corpus
LEMMA_CORPUS_INDEX_URL=""
LEMMA_CORPUS_OUTPUT_DIR="corpus"
LEMMA_OPERATOR_DATA_DIR="validator-data"

# Validator scoring and active window
LEMMA_ACTIVE_K="20"
LEMMA_FRONTIER_DEPTH="0"
LEMMA_ACTIVE_QUEUE_SEED="lemma-active-queue-v1"
LEMMA_UNEARNED_ALLOCATION_POLICY="burn"
LEMMA_UNEARNED_UID="0"

# Miner prover adapter. The local command reads one JSON task from stdin and writes
# one JSON object with task_id and proof_script to stdout.
# LEMMA_PROVER_COMMAND="python prover.py"
LEMMA_PROVER_TIMEOUT_S="300"

# Optional OpenAI-compatible prover endpoint. This is provider-neutral; any
# compatible service can be used by miners.
# LEMMA_PROVER_BASE_URL="https://api.openai.com/v1"
# LEMMA_PROVER_API_KEY=""
# LEMMA_PROVER_MODEL=""

# Bittensor wallet names. Wallet files and secrets stay outside this repo.
BT_WALLET_COLD="default"
BT_WALLET_HOT="default"
BT_NETUID="0"

# Lean verification
LEAN_SANDBOX_IMAGE="lemma/lean-sandbox:latest"
LEAN_VERIFY_TIMEOUT_S="300"
LEAN_SANDBOX_CPU="2.0"
LEAN_SANDBOX_MEM_MB="8192"
LEAN_SANDBOX_NETWORK="none"
LEMMA_USE_DOCKER="true"
# Host Lean is local-debug only.
# LEMMA_ALLOW_HOST_LEAN="false"

# Optional workspace cache for Docker or remote-worker verification.
# LEMMA_LEAN_VERIFY_WORKSPACE_CACHE_DIR="/var/lib/lemma-lean-cache"
LEMMA_LEAN_WORKSPACE_CACHE_MAX_DIRS="8"
LEMMA_LEAN_WORKSPACE_CACHE_MAX_BYTES="17179869184"
LEMMA_LEAN_WORKSPACE_CACHE_INCLUDE_SUBMISSION_HASH="false"

# Optional long-lived Docker worker or HTTP worker.
# LEMMA_LEAN_DOCKER_WORKER="lemma-lean-worker"
# LEMMA_LEAN_VERIFY_REMOTE_URL="http://localhost:8787/verify"
# LEMMA_LEAN_VERIFY_REMOTE_BEARER=""
LEMMA_LEAN_VERIFY_REMOTE_TIMEOUT_MARGIN_S="30"
# LEMMA_LEAN_WORKER_ALLOW_UNAUTHENTICATED_NON_LOOPBACK="false"

LOG_LEVEL="INFO"

#!/usr/bin/env bash
set -euo pipefail

url="${LEMMA_CURRICULUM_STATE_URL:-}"
path="${LEMMA_CURRICULUM_STATE_JSONL:-}"
retarget="${LEMMA_CURRICULUM_RETARGET:-0}"
public="${LEMMA_CURRICULUM_STATE_PUBLIC:-0}"
protocol="${LEMMA_PROTOCOL_MODE:-dev}"

if [[ -z "$path" ]]; then
  exit 0
fi
if [[ -z "$url" ]]; then
  if [[ "$retarget" == "1" && "$public" == "1" && ( "$protocol" == "production" || "$protocol" == "testnet" ) ]]; then
    echo "production curriculum retargeting requires LEMMA_CURRICULUM_STATE_URL" >&2
    exit 1
  fi
  exit 0
fi

mkdir -p "$(dirname "$path")"
tmp="${path}.tmp.$$"
fetch_url="$url"
case "$url" in
  http://*|https://*)
    sep="?"
    [[ "$url" == *\?* ]] && sep="&"
    fetch_url="${url}${sep}t=$(date +%s)"
    ;;
esac
if curl -fsSL -H "Accept: application/vnd.github.raw" -H "Cache-Control: no-cache" "$fetch_url" -o "$tmp"; then
  if [[ -e "$path" ]] && cmp -s "$tmp" "$path"; then
    rm -f "$tmp"
    exit 0
  fi
  mv "$tmp" "$path"
  exit 0
fi
rm -f "$tmp"
if [[ ! -e "$path" ]]; then
  echo "curriculum state sync failed and no local public-state cache exists" >&2
  exit 1
fi

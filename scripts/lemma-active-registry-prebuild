#!/usr/bin/env bash
set -euo pipefail

workdir="${LEMMA_APP_DIR:-/opt/lemma-sn467/app}"
uv_bin="${LEMMA_UV_BIN:-uv}"
script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

export LEMMA_PREFER_PROCESS_ENV="${LEMMA_PREFER_PROCESS_ENV:-1}"

force_requested=0
for arg in "$@"; do
  if [[ "$arg" == "--force" ]]; then
    force_requested=1
  fi
done

lock_dir="${LEMMA_ACTIVE_REGISTRY_CACHE_DIR:-${TMPDIR:-/tmp}}"
mkdir -p "$lock_dir"
lock_path="${LEMMA_ACTIVE_REGISTRY_PREBUILD_LOCK:-$lock_dir/.prebuild.lock}"
exec 9>"$lock_path"
if ! flock -n 9; then
  echo '{"idle":true,"reason":"active registry prebuild already running"}'
  exit 0
fi

"${LEMMA_CURRICULUM_SYNC_BIN:-$script_dir/lemma-sync-curriculum-state}"

cd "$workdir"
cache_sync_output="$("$uv_bin" run python "$script_dir/lemma-sync-active-registry-cache")"
if [[ -n "$cache_sync_output" ]]; then
  echo "$cache_sync_output"
fi
if [[ "$force_requested" != "1" && ( "$cache_sync_output" == *'"cache": "present"'* || "$cache_sync_output" == *'"cache": "hydrated"'* ) ]]; then
  exit 0
fi
if [[ "${LEMMA_ACTIVE_REGISTRY_ROLE:-builder}" == "auditor" ]]; then
  echo '{"idle":true,"reason":"auditor mode waits for public active registry cache"}'
  exit 0
fi
if [[ "$force_requested" != "1" && -n "${LEMMA_ACTIVE_REGISTRY_CACHE_INDEX_URL:-}" ]]; then
  echo '{"idle":true,"reason":"public active registry cache not published yet"}'
  exit 0
fi
exec "$uv_bin" run lemma tasks warm-active-procedural-registry "$@"

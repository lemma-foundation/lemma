{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lemma Corpus Row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "row_id",
    "task_id",
    "task_version",
    "theorem_name",
    "type_expr",
    "statement",
    "imports",
    "lean_toolchain",
    "mathlib_rev",
    "policy",
    "target_sha256",
    "source_stream",
    "source_ref",
    "source_license",
    "proof_script",
    "proof_sha256",
    "proof_term_hash",
    "proof_identity",
    "proof_identity_source",
    "proof_identity_strength",
    "full_reward_eligible",
    "axiom_set",
    "solver_hotkey",
    "validator_hotkey",
    "epoch",
    "tempo",
    "accepted_at",
    "rewarded",
    "quality",
    "dependencies",
    "graph",
    "verification",
    "metadata"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "row_id": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "task_id": { "type": "string", "minLength": 1 },
    "task_version": { "type": "integer", "minimum": 1 },
    "theorem_name": { "type": "string", "minLength": 1 },
    "type_expr": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "imports": { "type": "array", "items": { "type": "string" } },
    "lean_toolchain": { "type": "string", "minLength": 1 },
    "mathlib_rev": { "type": "string", "minLength": 1 },
    "policy": { "type": "string", "minLength": 1 },
    "target_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_stream": { "type": "string", "minLength": 1 },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "path": { "type": ["string", "null"] }
      }
    },
    "source_license": { "type": "string", "minLength": 1 },
    "proof_script": { "type": "string", "minLength": 1 },
    "proof_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "proof_term_hash": { "type": ["string", "null"] },
    "proof_identity": { "type": "string", "minLength": 1 },
    "proof_identity_source": { "type": "string", "minLength": 1 },
    "proof_identity_strength": { "type": "string", "enum": ["weak", "medium", "strong"] },
    "full_reward_eligible": { "type": "boolean" },
    "axiom_set": { "type": "array", "items": { "type": "string" } },
    "solver_hotkey": { "type": "string", "minLength": 1 },
    "validator_hotkey": { "type": "string", "minLength": 1 },
    "epoch": { "type": ["integer", "null"] },
    "tempo": { "type": ["integer", "null"] },
    "active_K": { "type": ["integer", "null"], "minimum": 0 },
    "queue_position": { "type": ["integer", "null"], "minimum": 0 },
    "queue_depth": { "type": ["integer", "null"], "minimum": 0 },
    "frontier_depth": { "type": ["integer", "null"], "minimum": 0 },
    "ema_solve_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "accepted_at": { "type": "string", "minLength": 1 },
    "rewarded": { "type": "boolean" },
    "quality": { "type": "object" },
    "dependencies": { "type": "object" },
    "graph": { "type": ["object", "null"] },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "verifier_version", "elapsed_ms", "reason"],
      "properties": {
        "passed": { "type": "boolean", "const": true },
        "verifier_version": { "type": "string", "minLength": 1 },
        "elapsed_ms": { "type": ["integer", "null"] },
        "reason": { "type": ["string", "null"] }
      }
    },
    "metadata": { "type": "object" }
  }
}

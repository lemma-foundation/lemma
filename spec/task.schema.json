{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lemma Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "task_version",
    "source_stream",
    "source_ref",
    "source_license",
    "imports",
    "theorem_name",
    "type_expr",
    "statement",
    "submission_stub",
    "lean_toolchain",
    "mathlib_rev",
    "policy",
    "target_sha256"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "task_version": { "type": "integer", "minimum": 1 },
    "domain_id": { "type": "string", "const": "lean" },
    "verifier_id": { "type": "string", "minLength": 1 },
    "verifier_version": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "source_stream": {
      "type": "string",
      "enum": [
        "generated",
        "proof_repair",
        "theorem_variant",
        "premise_limited",
        "benchmark_practice",
        "human_curated",
        "mathlib_snapshot",
        "mathlib_perturbation",
        "state_graph",
        "auto_formalized",
        "conjecture_generated",
        "hard_target_variant",
        "trivial_curriculum"
      ]
    },
    "source_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": ["string", "null"] },
        "commit": { "type": ["string", "null"] },
        "path": { "type": ["string", "null"] }
      }
    },
    "source_license": { "type": "string", "minLength": 1 },
    "imports": { "type": "array", "items": { "type": "string" } },
    "theorem_name": { "type": "string", "minLength": 1 },
    "type_expr": { "type": "string", "minLength": 1 },
    "statement": { "type": "string", "minLength": 1 },
    "submission_stub": { "type": "string", "minLength": 1 },
    "lean_toolchain": { "type": "string", "minLength": 1 },
    "mathlib_rev": { "type": "string", "minLength": 1 },
    "policy": { "type": "string", "minLength": 1 },
    "target_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "queue_position": { "type": ["integer", "null"], "minimum": 0 },
    "queue_depth": { "type": "integer", "minimum": 0 },
    "frontier_depth": { "type": ["integer", "null"], "minimum": 0 },
    "triviality_status": {
      "type": "string",
      "enum": ["unknown", "trivial_curriculum", "paid_easy", "paid_medium", "paid_frontier"]
    },
    "activation_status": {
      "type": "string",
      "enum": ["paid", "curriculum", "benchmark", "quarantine", "rejected"]
    },
    "difficulty_band": {
      "type": "string",
      "enum": ["easy", "medium", "hard", "frontier"]
    },
    "active_epoch": { "type": ["integer", "null"] },
    "expires_epoch": { "type": ["integer", "null"] },
    "metadata": { "type": "object" }
  }
}
